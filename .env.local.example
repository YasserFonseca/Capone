# ── Supabase (anon key — seguro no frontend) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (service role — apenas server-side) ─────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Backend Express (Railway) ─────────────────────────────────────
# Usado apenas para fluxo de pagamentos (checkout, OAuth MP)
NEXT_PUBLIC_BACKEND_URL=https://api.seusite.com.br
BACKEND_URL=https://api.seusite.com.br
INTERNAL_API_KEY=

# ── Evolution API (WhatsApp) ──────────────────────────────────────
# URL pública do serviço Railway com a Evolution API
EVOLUTION_API_URL=https://evolution.up.railway.app
# Chave gerada por você — mínimo 32 chars, igual ao AUTHENTICATION_API_KEY do Railway
EVOLUTION_API_KEY=

# ── App URL (para gerar webhook URL corretamente) ─────────────────
# Em produção: https://seusite.com.br | Em dev local: use ngrok
NEXT_PUBLIC_APP_URL=https://seusite.com.br

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@capone.com.br
